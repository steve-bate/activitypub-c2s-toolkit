{
  "name": "activitypub-c2s-client",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "sidecar:dev": "tsx sidecar/server.ts",
    "sidecar:typecheck": "tsc -p tsconfig.sidecar.json --noEmit",
    "sidecar:build": "tsc -p tsconfig.sidecar.json",
    "sidecar:start": "node dist-sidecar/sidecar/server.js",
    "lint": "npx eslint . && npx vue-tsc --strict --noEmit && check-unused-comp && npx knip",
    "lint:dups": "jscpd --min-tokens 75 --ignore '**/node_modules/**,**/dist/**,**/.vite/**' src/"
  },
  "dependencies": {
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vue3-json-viewer": "github:steve-bate/vue3-json-viewer#dist"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.3.0",
    "jscpd": "^4.0.5",
    "knip": "^5.83.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.0.0",
    "vue-tsc": "^3.2.4"
  }
}
